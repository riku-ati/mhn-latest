# ─────────────────────────────────────────────────────────────────────────────
# MHN .env — copy this to .env and fill in real values.
# .env is gitignored and will never be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server identity ───────────────────────────────────────────────────────────
# Public URL sensors use to reach this MHN server (no trailing slash).
# Must be reachable from every sensor box on port 8080.
SERVER_BASE_URL=http://YOUR_SERVER_IP:8080

# ── Security ──────────────────────────────────────────────────────────────────
# Flask session signing key — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-long-random-string

# Shared secret sensors present when registering themselves with /api/sensor/
# Generate with: python3 -c "import secrets; print(secrets.token_hex(16))"
DEPLOY_KEY=change-me-deploy-key

# hpfeeds subscriber password used by the mnemosyne collector container.
# Can be any random string — it never leaves the server.
MNEMOSYNE_SECRET=change-me-mnemosyne-secret

# ── Admin account (used by initdatabase.py) ───────────────────────────────────
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=change-me-strong-password

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite path inside the mhn_db Docker volume (default works fine).
# Switch to PostgreSQL: postgresql+psycopg2://user:pass@host/dbname
SQLALCHEMY_DATABASE_URI=sqlite:////app/db/mhn.db

# ── MongoDB (shared by mhn, celery, hpfeeds-broker, mnemosyne) ────────────────
MONGODB_HOST=mongodb
MONGODB_PORT=27017

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Email (optional — for password reset) ────────────────────────────────────
MAIL_SERVER=
MAIL_PORT=25
MAIL_USE_TLS=false
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
DEFAULT_MAIL_SENDER=mhn@example.com

# ── Misc ──────────────────────────────────────────────────────────────────────
DEBUG=false
